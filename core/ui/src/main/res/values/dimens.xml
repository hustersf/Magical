<?xml version="1.0" encoding="utf-8"?>
<resources>
  <!-- ================================================================= -->
  <!-- 基础网格间距 (Spacing Tokens) - 单位 [dp]                            -->
  <!-- ================================================================= -->
  <!-- 超小间距：用于图文微调与密集行距 -->
  <dimen name="core_ui_spacing_xs">4dp</dimen>
  <!-- 小间距：用于组件内部子元素关联间距 -->
  <dimen name="core_ui_spacing_sm">8dp</dimen>
  <!-- 中间距：标准的列表项/卡片组件内衬 (Padding) -->
  <dimen name="core_ui_spacing_md">12dp</dimen>
  <!-- 大间距：全局页面外边距 (Page Margin) 与主卡片内衬 -->
  <dimen name="core_ui_spacing_lg">16dp</dimen>
  <!-- 特大间距：独立功能区块之间的分界留白 -->
  <dimen name="core_ui_spacing_xl">24dp</dimen>
  <!-- 巨大间距：页面顶部/底部的起始大面积留白 -->
  <dimen name="core_ui_spacing_xxl">32dp</dimen>

  <!-- ================================================================= -->
  <!-- 组件圆角规范 (Corner Radius Tokens) - 单位 [dp]                       -->
  <!-- ================================================================= -->
  <!-- 中圆角：用于标准列表卡片、多选项背景剪裁 -->
  <dimen name="core_ui_corner_radius_md">12dp</dimen>
  <!-- 大圆角：用于主视觉容器、底部弹窗 (BottomSheet) -->
  <dimen name="core_ui_corner_radius_lg">16dp</dimen>
  <!-- 全圆角：用于胶囊按钮、圆形头像、状态标签 -->
  <dimen name="core_ui_corner_radius_pill">999dp</dimen>

  <!-- ================================================================= -->
  <!-- 卡片组件物理常量 (Card Tokens) - 单位 [dp]                           -->
  <!-- ================================================================= -->
  <!-- 卡片标准阴影高度：赋予卡片自然的漂浮立体感 -->
  <dimen name="core_ui_card_elevation">2dp</dimen>
  <!-- 卡片标准描边线宽：0dp 代表纯阴影切分，无死板粗边框 -->
  <dimen name="core_ui_card_stroke">0.5dp</dimen>

  <!-- 全局标准圆形进度条的轨道厚度（设计系统规范） -->
  <dimen name="core_ui_progress_track_thickness_standard">5dp</dimen>

  <!-- ================================================================= -->
  <!-- 按钮组件物理常量 (Button Tokens) - 单位 [dp]                         -->
  <!-- ================================================================= -->
  <!-- 小号/辅助按钮的标准固定高度：用于卡片内次要操作、一键清理或辅助行动点 -->
  <dimen name="core_ui_button_height_small">36dp</dimen>
  <!-- 标准/主行动按钮的视觉高度：符合移动端核心点击区域的标准设计 -->
  <dimen name="core_ui_button_height_standard">48dp</dimen>

  <!-- 业界标准无感操作图标热区大小（符合 Google MD3 无障碍最小触控热区建议） -->
  <dimen name="core_ui_touch_target_action_icon">40dp</dimen>
  <!-- 标准行内次要状态图标的物理尺寸（如卡片内的状态指示勾选框、小警告图标） -->
  <dimen name="core_ui_inline_status_icon">16dp</dimen>
</resources>
