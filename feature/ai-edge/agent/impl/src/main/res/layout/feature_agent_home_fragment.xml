<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/agent_home_toolbar"
    android:layout_width="0dp"
    android:layout_height="@dimen/core_ui_toolbar_height_standard"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:title="@string/feature_agent_home_title"
    app:titleCentered="true"
    app:titleTextAppearance="@style/CoreUiTextAppearance.Header">

    <ImageButton
      android:id="@+id/agent_home_add_btn"
      android:layout_width="@dimen/core_ui_touch_target_action_icon"
      android:layout_height="@dimen/core_ui_touch_target_action_icon"
      android:layout_gravity="end"
      android:layout_marginEnd="@dimen/core_ui_spacing_lg"
      android:background="?attr/selectableItemBackgroundBorderless"
      android:contentDescription="@string/feature_agent_action_create"
      android:padding="@dimen/core_ui_touch_target_action_icon_padding"
      android:scaleType="centerInside"
      android:src="@drawable/core_ic_circle_more" />

  </com.google.android.material.appbar.MaterialToolbar>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/agent_home_list"
    android:layout_width="0dp"
    android:layout_height="0dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/agent_home_toolbar" />

</androidx.constraintlayout.widget.ConstraintLayout>