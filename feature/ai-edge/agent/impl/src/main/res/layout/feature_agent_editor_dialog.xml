<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="@dimen/core_ui_spacing_sm"
    android:paddingTop="@dimen/core_ui_spacing_sm">

    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="@string/feature_agent_field_avatar">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/agent_editor_avatar_et"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/core_ui_spacing_sm"
      android:hint="@string/feature_agent_field_name">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/agent_editor_name_et"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPersonName|textCapWords"
        android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/core_ui_spacing_sm"
      android:hint="@string/feature_agent_field_model_id">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/agent_editor_model_id_et"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/core_ui_spacing_sm"
      android:hint="@string/feature_agent_field_prompt">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/agent_editor_prompt_et"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="5" />

    </com.google.android.material.textfield.TextInputLayout>

  </LinearLayout>

</ScrollView>